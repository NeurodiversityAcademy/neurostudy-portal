{
  "name": "neurostudy-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "eslint src --quiet",
    "dev": "next dev",
    "prebuild": "npm run verify:quality",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=low",
    "test": "NODE_ENV=test jest --passWithNoTests --maxWorkers=75%",
    "test:coverage": "NODE_ENV=test jest --coverage --passWithNoTests --maxWorkers=75%",
    "test:ci": "NODE_ENV=test SILENT_TEST_CONSOLE=1 jest --ci --silent --coverage --passWithNoTests --maxWorkers=75% --workerIdleMemoryLimit=512MB",
    "coverage:changed": "node scripts/check-changed-coverage.mjs",
    "verify:quality": "npm run security:audit && npm run format:check && npm run lint && npm run typecheck && npm run test:ci && npm run coverage:changed",
    "vercel:build": "npm run verify:quality && next build",
    "verify:deploy": "npm run vercel:build",
    "deploy": "npm run vercel:build"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1088.0",
    "@aws-sdk/lib-dynamodb": "^3.1088.0",
    "@aws-sdk/util-dynamodb": "^3.996.7",
    "@netlify/plugin-nextjs": "^5.15.12",
    "@next/third-parties": "^16.2.10",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "aws-amplify": "^6.18.0",
    "axios": "^1.18.1",
    "classnames": "^2.5.1",
    "embla-carousel-react": "^8.6.0",
    "next": "^16.2.10",
    "next-auth": "5.0.0-beta.31",
    "rate-limiter-flexible": "^11.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-facebook-pixel": "^1.0.4",
    "react-hook-form": "^7.81.0",
    "react-icons": "^5.7.0",
    "stripe": "^22.3.1",
    "uuid": "^14.0.1",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
